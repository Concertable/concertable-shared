<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="BCrypt.Net-Next" />
    <PackageReference Include="Duende.IdentityServer" />
    <PackageReference Include="Duende.IdentityServer.EntityFramework" />
    <PackageReference Include="Microsoft.EntityFrameworkCore.Design">
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
      <PrivateAssets>all</PrivateAssets>
    </PackageReference>
    <PackageReference Include="Refit.HttpClientFactory" />
  </ItemGroup>

  <!-- Shared platform + Auth.Contracts as feed packages (versions in Directory.Packages.props).
       Keep these as PackageReferences, never ProjectReferences, so Auth carves out standalone. -->
  <ItemGroup>
    <PackageReference Include="Concertable.Auth.Contracts" />
    <PackageReference Include="Concertable.Seed.Shared" />
    <PackageReference Include="Concertable.Seed.Identity" />
    <PackageReference Include="Concertable.DataAccess.Application" />
    <PackageReference Include="Concertable.DataAccess.Infrastructure" />
    <PackageReference Include="Concertable.Messaging.AzureServiceBus" />
    <PackageReference Include="Concertable.ServiceDefaults" />
    <PackageReference Include="Concertable.Messaging.Infrastructure" />
    <PackageReference Include="Concertable.Shared.Blob.Infrastructure" />
    <PackageReference Include="Concertable.Shared.Email.Infrastructure" />
    <PackageReference Include="Concertable.Shared.Geocoding.Infrastructure" />
    <PackageReference Include="Concertable.Shared.Imaging.Infrastructure" />
    <PackageReference Include="Concertable.Shared.Pdf.Infrastructure" />
  </ItemGroup>

</Project>
