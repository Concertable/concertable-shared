<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
  </PropertyGroup>

  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="FluentResults" />
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" />
    <PackageReference Include="Microsoft.EntityFrameworkCore.SqlServer" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Concertable.B2B.Contract.Contracts\Concertable.B2B.Contract.Contracts.csproj" />
    <ProjectReference Include="..\Concertable.B2B.Contract.Domain\Concertable.B2B.Contract.Domain.csproj" />
    <ProjectReference Include="..\Concertable.B2B.Contract.Application\Concertable.B2B.Contract.Application.csproj" />
    <ProjectReference Include="..\..\..\Concertable.B2B.DataAccess\Concertable.B2B.DataAccess.Infrastructure\Concertable.B2B.DataAccess.Infrastructure.csproj" />
    <ProjectReference Include="..\..\..\..\Concertable.B2B\Seed\Concertable.B2B.Seed.Infrastructure\Concertable.B2B.Seed.Infrastructure.csproj" />
    <!-- TEMPORARY: legacy hosts retire as Payment + remaining Concertable.* extracts. -->
  </ItemGroup>

  <!-- Never a ProjectReference: would break B2B's standalone carve. The churny core
       (Kernel, Messaging.*) is swapped back to ProjectReferences by Directory.Build.targets
       when UseLocalCore=true; everything else is package-only. -->
  <ItemGroup>
    <PackageReference Include="Concertable.DataAccess.Infrastructure" />
    <PackageReference Include="Concertable.Kernel" />
    <PackageReference Include="Concertable.Seed.Shared" />
  </ItemGroup>

</Project>
