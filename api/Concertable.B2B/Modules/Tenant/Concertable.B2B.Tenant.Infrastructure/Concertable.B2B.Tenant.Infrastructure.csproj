<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
  </PropertyGroup>

  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="FluentValidation.DependencyInjectionExtensions" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Concertable.B2B.Tenant.Contracts\Concertable.B2B.Tenant.Contracts.csproj" />
    <ProjectReference Include="..\Concertable.B2B.Tenant.Application\Concertable.B2B.Tenant.Application.csproj" />
    <ProjectReference Include="..\..\..\Seed\Concertable.B2B.Seed.Infrastructure\Concertable.B2B.Seed.Infrastructure.csproj" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\..\Concertable.B2B.DataAccess\Concertable.B2B.DataAccess.Infrastructure\Concertable.B2B.DataAccess.Infrastructure.csproj" />
  </ItemGroup>

  <!-- Never a ProjectReference: would break B2B's standalone carve. The churny core
       (Kernel, Messaging.*) is swapped back to ProjectReferences by Directory.Build.targets
       when UseLocalCore=true; everything else is package-only. -->
  <ItemGroup>
    <PackageReference Include="Concertable.Auth.Contracts" />
    <PackageReference Include="Concertable.DataAccess.Infrastructure" />
    <PackageReference Include="Concertable.Kernel" />
    <PackageReference Include="Concertable.Messaging.Contracts" />
    <PackageReference Include="Concertable.Seed.Shared" />
  </ItemGroup>

</Project>
