<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <IsPackable>true</IsPackable>
    <Description>Concertable B2B Tenant contracts: the cross-service tenant/permission contract surface and integration events (incl. TenantCreatedEvent) consumed by services downstream of B2B.</Description>
  </PropertyGroup>

  <ItemGroup>
    <!-- AuthorizeAttribute for [HasPermission], the cross-module authz surface. -->
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>

  <!-- Never a ProjectReference: would break B2B's standalone carve. The churny core
       (Kernel, Messaging.*) is swapped back to ProjectReferences by Directory.Build.targets
       when UseLocalCore=true; everything else is package-only. -->
  <ItemGroup>
    <PackageReference Include="Concertable.Contracts" />
    <PackageReference Include="Concertable.Kernel" />
    <PackageReference Include="Concertable.Messaging.Contracts" />
  </ItemGroup>

</Project>
