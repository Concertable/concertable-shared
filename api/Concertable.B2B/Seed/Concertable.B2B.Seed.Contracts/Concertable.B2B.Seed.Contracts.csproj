<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <IsPackable>true</IsPackable>
    <Description>Concertable B2B seed contracts: the canonical B2B seed catalog (Artist/Venue/Concert seed specs + their ToEvent() mappers) consumed by B2B's own seeders, its Seed.Simulator, and downstream consumers' projection-test seeders.</Description>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\Modules\Venue\Concertable.B2B.Venue.Contracts\Concertable.B2B.Venue.Contracts.csproj" />
    <ProjectReference Include="..\..\Modules\Artist\Concertable.B2B.Artist.Contracts\Concertable.B2B.Artist.Contracts.csproj" />
    <ProjectReference Include="..\..\Modules\Concert\Concertable.B2B.Concert.Contracts\Concertable.B2B.Concert.Contracts.csproj" />
  </ItemGroup>

  <!-- Never a ProjectReference: would break B2B's standalone carve. The churny core
       (Kernel, Messaging.*) is swapped back to ProjectReferences by Directory.Build.targets
       when UseLocalCore=true; everything else is package-only. -->
  <ItemGroup>
    <PackageReference Include="Concertable.Seed.Identity" />
  </ItemGroup>

</Project>
