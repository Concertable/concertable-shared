<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\Concertable.B2B.DataAccess.Application\Concertable.B2B.DataAccess.Application.csproj" />
    <ProjectReference Include="..\..\Modules\User\Concertable.B2B.User.Domain\Concertable.B2B.User.Domain.csproj" />
    <ProjectReference Include="..\..\Modules\Artist\Concertable.B2B.Artist.Domain\Concertable.B2B.Artist.Domain.csproj" />
    <ProjectReference Include="..\..\Modules\Venue\Concertable.B2B.Venue.Domain\Concertable.B2B.Venue.Domain.csproj" />
